{
  "name": "agentic30-sidecar",
  "private": true,
  "type": "module",
  "scripts": {
    "sidecar": "node sidecar/index.mjs",
    "mcp": "node sidecar/mcp-server.mjs",
    "acp": "node sidecar/acp-adapter.mjs",
    "doctor": "node sidecar/preflight-cli.mjs",
    "posthog:mcp:dry-run": "node sidecar/posthog-mcp-config-cli.mjs dry-run",
    "posthog:mcp:sync": "node sidecar/posthog-mcp-config-cli.mjs sync",
    "preflight:release": "node sidecar/preflight-cli.mjs",
    "preflight:bundle": "node scripts/preflight-bundle.mjs",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "eval:dogfood": "node sidecar-evals/dogfood-simulation.mjs",
    "eval:dogfood:gate": "node sidecar-evals/dogfood-simulation.mjs --gate",
    "eval:dogfood:live": "AGENTIC30_RUN_LIVE_PROVIDER_EVAL=1 node sidecar-evals/dogfood-simulation.mjs",
    "eval:dogfood:summary": "node sidecar-evals/dogfood-summary.mjs",
    "eval:dogfood:compare": "node sidecar-evals/dogfood-compare.mjs",
    "report:timings": "node scripts/report-response-timings.mjs",
    "track:release-funnel": "node scripts/posthog-release-funnel.mjs",
    "sync:gstack": "node scripts/sync-gstack.mjs",
    "sync:alignment": "node scripts/sync-alignment-sources.mjs",
    "check:public-safety": "node scripts/check-public-safety.mjs",
    "check:alignment-leak": "node scripts/check-alignment-leak.mjs",
    "scan:secrets:gh": "bash scripts/scan-secrets-gh.sh",
    "hooks:install": "git config core.hooksPath scripts/git-hooks",
    "hooks:uninstall": "git config --unset core.hooksPath",
    "test:sidecar": "node --test sidecar-tests/**/*.test.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.87",
    "@google/genai": "^2.3.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex-sdk": "0.125.0",
    "@tobilu/qmd": "2.1.0",
    "ws": "8.18.3",
    "zod": "4.1.12"
  },
  "devDependencies": {
    "bun": "^1.3.13"
  }
}
